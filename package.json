{
  "name": "bigbazzar",
  "private": true,
  "version": "1.0.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:ios-web": "tsc -b && vite build --base ./ --outDir dist-ios",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "release:tf": "python3 ios/scripts/release_testflight.py",
    "perf:p1-check": "python3 scripts/perf_p1_check.py",
    "agent:new": "python3 scripts/create_agent_session.py",
    "build:android-web": "tsc -b && vite build --base ./ --outDir dist-android",
    "android:sync": "npx cap sync android",
    "android:open": "npx cap open android"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.1.0",
    "@types/node": "^22.0.0",
    "typescript": "~5.8.3",
    "vite": "^6.3.1",
    "vitest": "^3.1.1"
  },
  "dependencies": {
    "@capacitor/android": "^8.1.0",
    "@capacitor/core": "^8.1.0",
    "pixi.js": "^8.9.2",
    "peerjs": "^1.5.4"
  }
}
